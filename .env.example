# Cloudflare Worker URL (MEXC + news + Telegram alerts).
# Example: https://mexc-proxy.your-account.workers.dev
VITE_MEXC_PROXY_URL=

# Same value as worker secret ALERT_SECRET (protects POST /telegram/alert)
VITE_ALERT_SECRET=

# Bot username without @ ( fore open-bot link in UI )
VITE_TELEGRAM_BOT_USERNAME=
